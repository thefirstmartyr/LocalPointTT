{
  "instructions": "Copy this file to config/secrets/secrets.json and fill in your actual values",
  "warning": "DO NOT commit real API keys to this template file!",
  
  "api_keys": {
    "google_maps": "YOUR_GOOGLE_MAPS_API_KEY",
    "stripe_publishable": "YOUR_STRIPE_PUBLISHABLE_KEY",
    "stripe_secret": "YOUR_STRIPE_SECRET_KEY",
    "firebase_web_api_key": "YOUR_FIREBASE_API_KEY"
  },
  
  "firebase": {
    "project_id": "YOUR_PROJECT_ID",
    "messaging_sender_id": "YOUR_SENDER_ID",
    "app_id": "YOUR_APP_ID",
    "auth_domain": "your-project.firebaseapp.com",
    "storage_bucket": "your-project.appspot.com"
  },
  
  "urls": {
    "api_base": "https://your-api-url.com",
    "cdn_base": "https://your-cdn-url.com"
  },
  
  "environment": {
    "name": "development",
    "debug": true,
    "log_level": "verbose"
  },
  
  "features": {
    "push_notifications_enabled": true,
    "analytics_enabled": false,
    "crash_reporting_enabled": false
  }
}
